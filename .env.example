# ============================================================
# SQA Knowledge Base — Variables de entorno (raíz)
# ============================================================
# Copiá este archivo a `.env` en la raíz del monorepo y rellená los valores.
# Las credenciales sensibles (Anthropic API key, conexiones reales) NUNCA van
# en `.env`. Para esos secretos:
#
#   - En desarrollo local: ponelos en `C:\AriaAppGK\credentials.env`
#     (fuera del repo, gitignored como defensa adicional).
#   - En CI / staging / prod: van en GitHub Secrets / Azure Key Vault.
#
# El docker-compose y los scripts de Make leen primero `.env` y luego, si existe,
# `../credentials.env` (override) — así que credentials.env gana siempre.
# ============================================================

# ---------- App ----------
APP_ENV=dev                        # dev | staging | prod | test
LOG_LEVEL=INFO

# ---------- Backend (FastAPI) ----------
SQA_KB_APP_ENV=dev
SQA_KB_API_V1_PREFIX=/api/v1
SQA_KB_CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# ---------- Frontend (Next.js) ----------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_AUTH_MODE=stub         # stub | msal
NEXT_PUBLIC_ENTRA_CLIENT_ID=
NEXT_PUBLIC_ENTRA_TENANT_ID=
NEXT_PUBLIC_ENTRA_REDIRECT_URI=http://localhost:3000/auth/callback

# ---------- PostgreSQL + pgvector ----------
POSTGRES_USER=sqa
POSTGRES_PASSWORD=sqa_dev_password
POSTGRES_DB=sqa_kb
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://sqa:sqa_dev_password@localhost:5432/sqa_kb

# ---------- Azurite (Blob Storage emulado local) ----------
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEhibT2EMV6Hod2qWmGXOZAH7sHpV/jVQYUbqHdK4xJk6Q/EOPpJjMfBR2cMo3w==;BlobEndpoint=http://localhost:10000/devstoreaccount1;
AZURE_BLOB_CONTAINER_DOCS=base-conocimiento
AZURE_BLOB_CONTAINER_INBOX=inbox-pendientes
AZURE_BLOB_CONTAINER_DRAFTS=borradores

# ---------- Redis (workers async) ----------
REDIS_URL=redis://localhost:6379/0

# ---------- LLM (Anthropic) ----------
# NUNCA poner la clave real acá. Ponela en `C:\AriaAppGK\credentials.env`
# con la variable ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_KEY=__set_in_credentials.env__
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
ANTHROPIC_MODEL_DEEP=claude-opus-4-7

# ---------- Embeddings ----------
EMBEDDINGS_PROVIDER=cohere         # cohere | openai | local-bge
COHERE_API_KEY=__set_in_credentials.env__

# ---------- Observabilidad ----------
APPLICATIONINSIGHTS_CONNECTION_STRING=
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=__set_in_credentials.env__
