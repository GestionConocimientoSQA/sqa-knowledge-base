SQA_KB_APP_ENV=dev
SQA_KB_API_V1_PREFIX=/api/v1
SQA_KB_CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# Postgres local (docker-compose). Cambiar a Azure/TI cuando esté el servicio.
SQA_KB_DATABASE_URL=postgresql+asyncpg://sqa:sqa_dev_password@localhost:5432/sqa_kb

# LLM gateway — Fase 2. La key vive en credentials.env (fuera del repo).
# Cuando TI provea LiteLLM, swap a SQA_KB_LLM_GATEWAY_KIND=litellm.
SQA_KB_LLM_GATEWAY_KIND=anthropic_direct
# SQA_KB_ANTHROPIC_API_KEY=sk-ant-...   # cargar desde credentials.env, no acá
