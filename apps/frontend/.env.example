# API
# Setear a la URL del backend FastAPI local (sin trailing slash). Cuando
# está vacío, el frontend cae a los mocks-stub de `lib/api/*` (no necesita
# backend para correr tests o navegar la UI).
#
# Dev local con backend 1B corriendo en :8000 → usar exactamente este valor
# para que ky resuelva contra los routers `/auth`, `/sessions`, etc.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Auth (Entra ID — placeholder values for stub mode)
NEXT_PUBLIC_AUTH_MODE=stub
NEXT_PUBLIC_ENTRA_CLIENT_ID=
NEXT_PUBLIC_ENTRA_TENANT_ID=
NEXT_PUBLIC_ENTRA_REDIRECT_URI=http://localhost:3000/auth/callback

# Telemetry
NEXT_PUBLIC_APPINSIGHTS_CONNECTION_STRING=
